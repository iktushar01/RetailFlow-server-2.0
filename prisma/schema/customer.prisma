model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales         Sale[]
  salesPayments SalesPayment[]

  @@index([phone])
  @@index([name])
  @@map("customers")
}
