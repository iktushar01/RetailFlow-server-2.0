model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  address   String?
  capacity  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItems       Inventory[]
  grnsAsDestination    Grn[]             @relation("GrnDestinationWarehouse")
  stockTransfersFrom   StockTransfer[]   @relation("TransferSourceWarehouse")
  stockTransfersTo     StockTransfer[]   @relation("TransferDestinationWarehouse")

  @@map("warehouses")
}
